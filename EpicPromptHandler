-- Purpose: Detects player interaction and fires the OpenEpicShop remote to the client.
-- Runs on: Server
-- Location: Workspace > [Your Epic NPC] > ProximityPrompt > EpicPromptHandler
-- Dependencies: ReplicatedStorage.ShopRemotes.OpenEpicShop
-- Public API: None
-- Networking: Fires OpenEpicShop (Server -> Client)
-- Security: Relies on ProximityPrompt's built-in distance and line-of-sight verifications.
-- Performance: O(1) event connection, minimal memory footprint.
-- Notes: Must be placed directly inside the ProximityPrompt instance.

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local prompt = script.Parent
if not prompt:IsA("ProximityPrompt") then
	warn("⚠️ [EpicPromptHandler] This script must be placed directly inside a ProximityPrompt!")
	return
end

-- Wait for the network setup script to create the folders/remotes
local ShopRemotes = ReplicatedStorage:WaitForChild("ShopRemotes")
local OpenEpicShop = ShopRemotes:WaitForChild("OpenEpicShop")

prompt.Triggered:Connect(function(player)
	if player and player:IsA("Player") then
		-- Tell the specific player's client to open the Epic Shop UI
		OpenEpicShop:FireClient(player)
	end
end)
