-- Purpose: Handles secure Bank <-> ATM <-> Wallet transfers with transaction locking and rate limits.
-- Runs on: Server
-- Location: ServerScriptService
-- Dependencies: ReplicatedStorage, Workspace, Players
-- Public API: WithdrawFunction (RemoteFunction)
-- Networking: Client invokes WithdrawFunction -> Server processes -> Returns boolean, string
-- Security: Transaction locks prevent race conditions, strict type validation, upper limits on amount.
-- Performance: Early exit checks prevent expensive Workspace lookups for malformed requests.
-- Notes: Failsafe distance check included. Requires ATM Manager NPC to be loaded.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

local withdrawFunc = ReplicatedStorage:WaitForChild("WithdrawFunction")

local NPC_FOLDER_NAME = "NPCS"
local MANAGER_NAME = "AfraiC4t"
local MAX_DISTANCE = 20 -- Studs (For Physical Withdraw only)
local MAX_AMOUNT_LIMIT = 1000000000000 -- 1 Trillion safety cap

-- 🛡️ SECURITY: Transaction Locks
local activeTransactions = {}

-- [[ 1. TRANSFER: BANK -> ATM (Remote / App) ]]
local function TransferToATM(player, amount)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return false, "Data Error" end

	local bank = leaderstats:FindFirstChild("Cash")
	local atm = leaderstats:FindFirstChild("ATMBalance")

	if not bank or not atm then return false, "Missing Values" end

	if bank.Value >= amount then
		bank.Value -= amount
		atm.Value += amount
		print("📱 Mobile Transfer: " .. player.Name .. " moved $"..amount.." to ATM.")
		return true, "Transfer Successful! Visit ATM to collect."
	else
		return false, "Insufficient Bank Funds"
	end
end

-- [[ 2. WITHDRAW: ATM -> WALLET (Physical / NPC) ]]
local function WithdrawFromATM(player, amount)
	-- 🛑 DISTANCE CHECK (Security)
	local npcFolder = Workspace:FindFirstChild(NPC_FOLDER_NAME)
	local managerNPC = npcFolder and npcFolder:FindFirstChild(MANAGER_NAME)

	-- 🛡️ SECURITY FIX: Fail Safe Logic
	if managerNPC then
		local npcRoot = managerNPC:FindFirstChild("HumanoidRootPart") or managerNPC.PrimaryPart
		local pRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")

		if npcRoot and pRoot then
			if (pRoot.Position - npcRoot.Position).Magnitude > MAX_DISTANCE then
				return false, "You are too far from the ATM!"
			end
		else
			return false, "Security Check Failed: Physics not loaded."
		end
	else
		warn("⚠️ ATM Manager NPC missing. Transaction Denied for Security.")
		return false, "ATM Unavailable: Security Verification Failed"
	end

	local leaderstats = player:FindFirstChild("leaderstats")
	local atm = leaderstats and leaderstats:FindFirstChild("ATMBalance")
	local wallet = leaderstats and leaderstats:FindFirstChild("Wallet")

	if not atm or not wallet then return false, "Data Error" end

	if atm.Value >= amount then
		atm.Value -= amount
		wallet.Value += amount
		print("🏧 Physical Withdraw: " .. player.Name .. " took $"..amount.." from ATM.")
		return true, "Cash Withdrawn to Wallet!"
	else
		return false, "Insufficient Funds in ATM. Transfer from Bank first."
	end
end

-- [[ MAIN HANDLER ]]
withdrawFunc.OnServerInvoke = function(player, amount, actionType)
	-- 1. Strict Type & Bound Validation
	if type(actionType) ~= "string" then return false, "Invalid Action Type" end
	if type(amount) ~= "number" or amount <= 0 or amount ~= amount or amount >= MAX_AMOUNT_LIMIT then
		return false, "Invalid Amount"
	end
	amount = math.floor(amount)

	-- 2. Transaction Lock (Prevents Race Conditions & Spam)
	if activeTransactions[player.UserId] then
		return false, "Transaction in progress. Please wait."
	end
	activeTransactions[player.UserId] = true

	-- 3. Route Request Safely via pcall
	local success, result, msg = pcall(function()
		if actionType == "Transfer" then
			return TransferToATM(player, amount)
		elseif actionType == "Withdraw" then
			return WithdrawFromATM(player, amount)
		else
			warn("⚠️ Unknown Transaction Type from " .. player.Name .. ": " .. tostring(actionType))
			return false, "System Error: Unknown Action"
		end
	end)

	-- 4. Release Lock reliably
	activeTransactions[player.UserId] = nil

	if not success then
		warn("⚠️ Transaction Error for " .. player.Name .. ": " .. tostring(result))
		return false, "System Error"
	end

	return result, msg
end

-- Cleanup locks if a player leaves mid-transaction
Players.PlayerRemoving:Connect(function(player)
	activeTransactions[player.UserId] = nil
end)
