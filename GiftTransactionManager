-- Purpose: Flawless, strictly server-authoritative ProximityPrompt & Remote-based gifting system.
-- Runs on: Server
-- Location: ServerScriptService
-- Dependencies: Players, ReplicatedStorage, ServerStorage, Workspace, HttpService
-- Public API: N/A
-- Networking: ReplicatedStorage.GiftRemotes (InitiateGift, ResolveGift, IncomingGift, GiftResult)
-- Security: Atomic debounces, strict type validation, escrow locking, magnitude checks, and parent verification.
-- Performance: DRY modularized logic, event connection pooling, O(1) state dictionary lookups.
-- Notes: Assumes TycoonDataHandler manages saving.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")
local Workspace = game:GetService("Workspace")
local HttpService = game:GetService("HttpService")

-- ⚙️ CONFIGURATION & CONSTANTS
local MAX_DISTANCE = 20
local TRANSACTION_TIMEOUT = 30
local INITIATE_COOLDOWN = 5

-- 📡 REMOTES SETUP
local Remotes = ReplicatedStorage:FindFirstChild("GiftRemotes") or Instance.new("Folder")
Remotes.Name = "GiftRemotes"
Remotes.Parent = ReplicatedStorage

local function getOrCreateRemote(name, class)
	local remote = Remotes:FindFirstChild(name) or Instance.new(class)
	remote.Name = name
	remote.Parent = Remotes
	return remote
end

local RequestInventoryToGift = getOrCreateRemote("RequestInventoryToGift", "RemoteEvent")
local InitiateGift = getOrCreateRemote("InitiateGift", "RemoteEvent")
local IncomingGift = getOrCreateRemote("IncomingGift", "RemoteEvent")
local ResolveGift = getOrCreateRemote("ResolveGift", "RemoteEvent")
local GiftResult = getOrCreateRemote("GiftResult", "RemoteEvent")

-- 🔒 STATE MANAGEMENT
local ActiveTransactions = {} -- [TransactionID] = { Sender, Receiver, Tool, Timer, UnequipConnection }
local PlayerCooldowns = {}    -- [UserId] = os.time()
local ActiveIncoming = {}     -- [UserId] = TransactionID
local LockedTools = {}        -- [ToolInstance] = TransactionID

-- 🛡️ HELPER FUNCTIONS
local function sendResult(player, success, message, toolId, isSender, otherPlayerName, otherPlayerId)
	if player and player.Parent then
		GiftResult:FireClient(player, success, message, toolId, isSender, otherPlayerName, otherPlayerId)
	end
end

local function isToolValidAndParented(player, tool)
	if not tool or not tool.Parent then return false end
	if not player.Character or tool.Parent ~= player.Character then return false end
	if not tool:GetAttribute("IssuedByServer") or not tool:GetAttribute("ToolId") then return false end
	return true
end

local function cancelTransaction(transactionId, reason, notifySender, notifyReceiver)
	local tx = ActiveTransactions[transactionId]
	if not tx then return end
	if tx.IsResolving then return end

	if tx.Tool then
		tx.Tool:SetAttribute("GiftLocked", nil)
		LockedTools[tx.Tool] = nil
	end

	if tx.Receiver and ActiveIncoming[tx.Receiver.UserId] == transactionId then
		ActiveIncoming[tx.Receiver.UserId] = nil
	end

	if tx.Timer then task.cancel(tx.Timer) end
	if tx.UnequipConnection then tx.UnequipConnection:Disconnect() end

	if notifySender then sendResult(tx.Sender, false, reason or "Transaction cancelled.") end
	if notifyReceiver then sendResult(tx.Receiver, false, reason or "Transaction cancelled.") end

	ActiveTransactions[transactionId] = nil
end

local function transferTool(sender, receiver, toolInstance)
	local toolId = toolInstance:GetAttribute("ToolId")
	if not toolId then return false end

	local CarTools = ServerStorage:FindFirstChild("CarTools")
	if not CarTools then return false end

	local sourceTool = CarTools:FindFirstChild(toolId)
	if not sourceTool then return false end

	local customAttributes = {}
	-- Copy attributes (e.g., IssuedByServer, ToolId, etc.) from live tool to the new ones
	for attrName, attrValue in pairs(toolInstance:GetAttributes()) do
		if attrName ~= "GiftLocked" and attrName ~= "IssuedByServer" and attrName ~= "IssuedAt" and attrName ~= "IssuedId" and attrName ~= "ToolId" then
			customAttributes[attrName] = attrValue
		end
	end

	local AdminAPI = game:GetService("ServerStorage"):FindFirstChild("TycoonAdminAPI")
	if AdminAPI then
		AdminAPI:Invoke("GiveTool", receiver, sourceTool.Name, customAttributes)
	else
		warn("⚠️ TycoonAdminAPI not found in GiftTransactionManager")
		return false
	end

	-- Destroy the original live tool to prevent engine desync
	toolInstance:Destroy()

	if sender:FindFirstChild("StarterGear") then
		for _, gear in pairs(sender.StarterGear:GetChildren()) do
			if gear:IsA("Tool") and gear:GetAttribute("ToolId") == toolId then
				gear:Destroy()
				break
			end
		end
	end

	local AdminAPI = ServerStorage:FindFirstChild("TycoonAdminAPI")
	if AdminAPI then
		task.spawn(function()
			pcall(function() AdminAPI:Invoke("MarkDirty", sender) end)
		end)
		task.spawn(function()
			pcall(function() AdminAPI:Invoke("MarkDirty", receiver) end)
		end)
	end

	return true
end

-- 🔄 CORE INITIATION LOGIC (Unified for Prompt & Remote)
local function attemptInitiateGift(sender, receiver, optionalToolInstance)
	if typeof(receiver) ~= "Instance" or not receiver:IsA("Player") or sender == receiver then return end
	if optionalToolInstance and (typeof(optionalToolInstance) ~= "Instance" or not optionalToolInstance:IsA("Tool")) then return end

	-- Debounce / Spam Prevention
	if sender:GetAttribute("IsInitiatingGift") then return end
	sender:SetAttribute("IsInitiatingGift", true)

	-- Rate Limit
	local lastAttempt = PlayerCooldowns[sender.UserId] or 0
	if os.time() - lastAttempt < INITIATE_COOLDOWN then
		sendResult(sender, false, "Please wait before gifting again.")
		sender:SetAttribute("IsInitiatingGift", nil)
		return
	end
	PlayerCooldowns[sender.UserId] = os.time()

	-- Distance Check
	local senderHrp = sender.Character and sender.Character:FindFirstChild("HumanoidRootPart")
	local receiverHrp = receiver.Character and receiver.Character:FindFirstChild("HumanoidRootPart")
	if not senderHrp or not receiverHrp then
		sender:SetAttribute("IsInitiatingGift", nil)
		return
	end
	if (senderHrp.Position - receiverHrp.Position).Magnitude > MAX_DISTANCE + 5 then
		sendResult(sender, false, "You are too far away from the player.")
		sender:SetAttribute("IsInitiatingGift", nil)
		return
	end

	-- Tool Resolution
	local toolInstance = optionalToolInstance
	if not toolInstance and sender.Character then
		for _, tool in pairs(sender.Character:GetChildren()) do
			if tool:IsA("Tool") and isToolValidAndParented(sender, tool) and not tool:GetAttribute("GiftLocked") and not LockedTools[tool] then
				toolInstance = tool
				break
			end
		end
	end

	if not toolInstance or not isToolValidAndParented(sender, toolInstance) then
		sendResult(sender, false, "You must have a valid car equipped to gift it.")
		sender:SetAttribute("IsInitiatingGift", nil)
		return
	end

	if toolInstance:GetAttribute("GiftLocked") or LockedTools[toolInstance] then
		sendResult(sender, false, "This car is already locked in a transaction.")
		sender:SetAttribute("IsInitiatingGift", nil)
		return
	end

	if ActiveIncoming[receiver.UserId] then
		sendResult(sender, false, receiver.Name .. " is currently busy with another transaction.")
		sender:SetAttribute("IsInitiatingGift", nil)
		return
	end

	-- Escrow Lock
	local transactionId = HttpService:GenerateGUID(false)
	toolInstance:SetAttribute("GiftLocked", true)
	LockedTools[toolInstance] = transactionId
	ActiveIncoming[receiver.UserId] = transactionId

	local timerThread = task.delay(TRANSACTION_TIMEOUT, function()
		cancelTransaction(transactionId, "Transaction timed out.", true, true)
	end)

	local unequipConnection = toolInstance.AncestryChanged:Connect(function(_, newParent)
		if newParent ~= sender.Character then
			cancelTransaction(transactionId, "Transaction cancelled because tool was unequipped or dropped.", true, true)
		end
	end)

	ActiveTransactions[transactionId] = {
		Sender = sender, Receiver = receiver, Tool = toolInstance, ToolId = toolInstance:GetAttribute("ToolId"),
		Timer = timerThread, UnequipConnection = unequipConnection, IsResolving = false
	}

	IncomingGift:FireClient(receiver, transactionId, sender, toolInstance:GetAttribute("ToolId"))
	sendResult(sender, true, "SENT_PENDING", toolInstance:GetAttribute("ToolId"), true, receiver.Name, receiver.UserId)

	sender:SetAttribute("IsInitiatingGift", nil)
end

-- 🎯 PROXIMITY PROMPT
local function injectPrompt(player, character)
	local hrp = character:WaitForChild("HumanoidRootPart", 10)
	if not hrp or hrp:FindFirstChild("GiftPrompt") then return end

	local prompt = Instance.new("ProximityPrompt")
	prompt.Name = "GiftPrompt"
	prompt.ActionText = "Gift"
	prompt.ObjectText = player.Name
	prompt.MaxActivationDistance = MAX_DISTANCE
	prompt.RequiresLineOfSight = false
	prompt.Enabled = false
	prompt.HoldDuration = 1
	prompt.Parent = hrp

	prompt.Triggered:Connect(function(sender)
		attemptInitiateGift(sender, player, nil)
	end)

	local humanoid = character:WaitForChild("Humanoid", 10)
	if humanoid then
		humanoid.Died:Connect(function()
			if prompt then
				prompt.Enabled = false
			end
		end)
	end
end

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function(char) injectPrompt(player, char) end)
end)
for _, p in ipairs(Players:GetPlayers()) do
	if p.Character then task.spawn(injectPrompt, p, p.Character) end
	p.CharacterAdded:Connect(function(char) injectPrompt(p, char) end)
end

-- 📡 REMOTE ENTRY
InitiateGift.OnServerEvent:Connect(function(sender, receiver, toolInstance)
	attemptInitiateGift(sender, receiver, toolInstance)
end)

-- 🏁 RESOLUTION
ResolveGift.OnServerEvent:Connect(function(player, transactionId, isAccepted)
	if typeof(transactionId) ~= "string" or typeof(isAccepted) ~= "boolean" then return end

	local tx = ActiveTransactions[transactionId]
	if not tx or tx.Receiver ~= player or tx.IsResolving then
		sendResult(player, false, "Transaction expired or invalid.")
		return
	end
	tx.IsResolving = true -- Atomic Lock

	if not isAccepted then
		tx.IsResolving = false
		cancelTransaction(transactionId, player.Name .. " declined the gift.", true, false)
		return
	end

	if not tx.Sender or not tx.Sender.Parent then
		tx.IsResolving = false
		cancelTransaction(transactionId, "Sender left the game.", false, true)
		return
	end

	local senderHrp = tx.Sender.Character and tx.Sender.Character:FindFirstChild("HumanoidRootPart")
	local receiverHrp = tx.Receiver.Character and tx.Receiver.Character:FindFirstChild("HumanoidRootPart")
	if not senderHrp or not receiverHrp or (senderHrp.Position - receiverHrp.Position).Magnitude > MAX_DISTANCE + 5 then
		tx.IsResolving = false
		cancelTransaction(transactionId, "Players moved too far apart.", true, true)
		return
	end

	if not isToolValidAndParented(tx.Sender, tx.Tool) then
		tx.IsResolving = false
		cancelTransaction(transactionId, "Tool is no longer valid or equipped incorrectly.", true, true)
		return
	end

	local success = transferTool(tx.Sender, tx.Receiver, tx.Tool)
	if success then
		-- Clear Lock strictly AFTER successful transfer
		LockedTools[tx.Tool] = nil
		if tx.Tool then
			tx.Tool:SetAttribute("GiftLocked", nil)
		end
		ActiveIncoming[tx.Receiver.UserId] = nil
		if tx.Timer then task.cancel(tx.Timer) end
		if tx.UnequipConnection then tx.UnequipConnection:Disconnect() end

		ActiveTransactions[transactionId] = nil
		sendResult(tx.Sender, true, "Gift successfully sent to " .. tx.Receiver.Name .. "!", tx.ToolId, true, tx.Receiver.Name, tx.Receiver.UserId)
		sendResult(tx.Receiver, true, "You received a gift from " .. tx.Sender.Name .. "!", tx.ToolId, false, tx.Sender.Name, tx.Sender.UserId)
	else
		cancelTransaction(transactionId, "Server error during transfer.", true, true)
	end
end)

-- 🧹 CLEANUP
Players.PlayerRemoving:Connect(function(player)
	for txId, tx in pairs(ActiveTransactions) do
		if tx.Sender == player then
			cancelTransaction(txId, "Sender left the game.", false, true)
		elseif tx.Receiver == player then
			cancelTransaction(txId, "Receiver left the game.", true, false)
		end
	end
	PlayerCooldowns[player.UserId] = nil
	ActiveIncoming[player.UserId] = nil
end)
