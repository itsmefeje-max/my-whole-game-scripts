-- Purpose: Detects player interaction and fires the OpenRareShop remote to the client.
-- Runs on: Server
-- Location: Workspace > [Your Rare NPC] > ProximityPrompt > RarePromptHandler
-- Dependencies: ReplicatedStorage.ShopRemotes.OpenRareShop
-- Public API: None
-- Networking: Fires OpenRareShop (Server -> Client)
-- Security: Relies on ProximityPrompt's built-in distance and line-of-sight verifications.
-- Performance: O(1) event connection, minimal memory footprint.
-- Notes: Must be placed directly inside the ProximityPrompt instance.

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local prompt = script.Parent
if not prompt:IsA("ProximityPrompt") then
	warn("⚠️ [RarePromptHandler] This script must be placed directly inside a ProximityPrompt!")
	return
end

-- Wait for the network setup script to create the folders/remotes
local ShopRemotes = ReplicatedStorage:WaitForChild("ShopRemotes")
local OpenRareShop = ShopRemotes:WaitForChild("OpenRareShop")

prompt.Triggered:Connect(function(player)
	if player and player:IsA("Player") then
		-- Tell the specific player's client to open the Rare Shop UI
		OpenRareShop:FireClient(player)
	end
end)
