-- Purpose: Swaps between the Day NPC (Harley) and Night NPC (Jacob) based on in-game time.
-- Runs on: Server
-- Location: ServerScriptService
-- Dependencies: Lighting, Workspace, ServerStorage
-- Public API: None
-- Networking: None
-- Security: Server-authoritative swapping to prevent client-side forcing.
-- Performance: Lightweight reparenting on state change; zero cloning or destroying.
-- Notes: Assumes both NPCs start in Workspace.NPCS or ServerStorage.OfflineNPCs.

local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local ServerStorage = game:GetService("ServerStorage")

local NIGHT_START = 18 -- 18:00 (6:00 PM)
local NIGHT_END = 6    -- 06:00 (6:00 AM)

local TARGET_NPC_NIGHT = "Jacob"
local TARGET_NPC_DAY = "Harley"

local npcFolder = Workspace:WaitForChild("NPCS")

-- Create a secure holding area for offline NPCs
local npcStorageFolder = ServerStorage:FindFirstChild("OfflineNPCs")
if not npcStorageFolder then
	npcStorageFolder = Instance.new("Folder")
	npcStorageFolder.Name = "OfflineNPCs"
	npcStorageFolder.Parent = ServerStorage
end

-- Secure NPCs on startup
local jacobNPC = npcFolder:FindFirstChild(TARGET_NPC_NIGHT) or npcStorageFolder:FindFirstChild(TARGET_NPC_NIGHT)
local harleyNPC = npcFolder:FindFirstChild(TARGET_NPC_DAY) or npcStorageFolder:FindFirstChild(TARGET_NPC_DAY)

if not jacobNPC then warn("⚠️ DayNightNPCManager: Could not find '" .. TARGET_NPC_NIGHT .. "'") end
if not harleyNPC then warn("⚠️ DayNightNPCManager: Could not find '" .. TARGET_NPC_DAY .. "'") end

local isCurrentlyNight = nil -- Set to nil initially to force the first update

local function checkTime()
	local time = Lighting.ClockTime

	-- Determine if current time falls within night hours
	local isNight = (time >= NIGHT_START) or (time < NIGHT_END)

	-- Only execute if the state has actually changed
	if isNight ~= isCurrentlyNight then
		isCurrentlyNight = isNight

		if isCurrentlyNight then
			-- Night: Spawn Jacob, Hide Harley
			print("🌙 Night Time: Spawning " .. TARGET_NPC_NIGHT .. " | Hiding " .. TARGET_NPC_DAY)
			if harleyNPC then harleyNPC.Parent = npcStorageFolder end
			if jacobNPC then jacobNPC.Parent = npcFolder end
		else
			-- Day: Spawn Harley, Hide Jacob
			print("☀️ Day Time: Spawning " .. TARGET_NPC_DAY .. " | Hiding " .. TARGET_NPC_NIGHT)
			if jacobNPC then jacobNPC.Parent = npcStorageFolder end
			if harleyNPC then harleyNPC.Parent = npcFolder end
		end
	end
end

-- 1. Initialize state immediately on boot
checkTime()

-- 2. Hook into the TimeDayNightCycleManager's clock progression
Lighting:GetPropertyChangedSignal("ClockTime"):Connect(checkTime)
