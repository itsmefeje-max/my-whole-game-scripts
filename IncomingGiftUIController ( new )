-- ----------------------------------------------------------------------------
-- ✨ HOVER EFFECT
-- ----------------------------------------------------------------------------
local function addHover(btn)
	if not btn or btn:GetAttribute("HoverAdded") then return end
	btn:SetAttribute("HoverAdded", true)

	local prop = nil
	if btn:IsA("ImageButton") or btn:IsA("ImageLabel") then
		prop = "ImageColor3"
	elseif btn:IsA("TextButton") or btn:IsA("TextLabel") or btn:IsA("Frame") then
		prop = "BackgroundColor3"
	end
	if not prop then return end

	btn.MouseEnter:Connect(function()
		TweenService:Create(btn, HOVER_TWEEN, {[prop] = DIM_COLOR}):Play()
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(btn, HOVER_TWEEN, {[prop] = NORMAL_COLOR}):Play()
	end)
end

addHover(acceptBtn)
addHover(declineBtn)

-- ----------------------------------------------------------------------------
-- 💾 STATE
-- ----------------------------------------------------------------------------
local currentTransactionId = nil
local isProcessing = false
local currentTween = nil
local closeThread = nil
local acceptConn = nil
local declineConn = nil

local senderNotifThread = nil

-- ----------------------------------------------------------------------------
-- 🔴 CLOSE
-- ----------------------------------------------------------------------------
local function closeMenu(delayTime)
	if closeThread then
		task.cancel(closeThread)
		closeThread = nil
	end

	closeThread = task.delay(delayTime or 0, function()
		if currentTween then
			currentTween:Cancel()
			currentTween = nil
		end

		if acceptConn then acceptConn:Disconnect() acceptConn = nil end
		if declineConn then declineConn:Disconnect() declineConn = nil end

		screenGui.Enabled = false
		currentTransactionId = nil
		isProcessing = false
	end)
end

-- ----------------------------------------------------------------------------
-- 🟢 SENDER NOTIFICATION HELPER
-- ----------------------------------------------------------------------------
local function showSenderNotification(tier, tierHex, carName, receiverName)
	local notificationsGui = PlayerGui:FindFirstChild("Notifications")
	if not notificationsGui then
		notificationsGui = Instance.new("ScreenGui")
		notificationsGui.Name = "Notifications"
		notificationsGui.ResetOnSpawn = false
		notificationsGui.Parent = PlayerGui
	end

	local notifLbl = notificationsGui:FindFirstChild("WhatIsSent")
	if not notifLbl then
		notifLbl = Instance.new("TextLabel")
		notifLbl.Name = "WhatIsSent"
		notifLbl.Size = UDim2.new(0, 400, 0, 50)
		notifLbl.Position = UDim2.new(0.5, 0, 0.8, 0)
		notifLbl.AnchorPoint = Vector2.new(0.5, 0.5)
		notifLbl.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
		notifLbl.Font = Enum.Font.GothamMedium
		notifLbl.RichText = true
		notifLbl.TextSize = 18
		notifLbl.TextColor3 = Color3.fromRGB(255, 255, 255)

		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0, 8)
		corner.Parent = notifLbl

		local stroke = Instance.new("UIStroke")
		stroke.Thickness = 2
		stroke.Color = Color3.fromRGB(255, 175, 55)
		stroke.Parent = notifLbl

		notifLbl.Parent = notificationsGui
	end

	notifLbl.Text = string.format("<font color='#%s'>[%s]</font> %s Has been sent to <font color='#ff0000'>@%s</font>", tierHex, tier, carName, sanitize(receiverName))
	notifLbl.Visible = true

	if senderNotifThread then
		task.cancel(senderNotifThread)
		senderNotifThread = nil
	end

	senderNotifThread = task.delay(4, function()
		if notifLbl then
			notifLbl.Visible = false
		end
		senderNotifThread = nil
	end)
end

-- ----------------------------------------------------------------------------
-- 🟢 INCOMING REQUEST
-- ----------------------------------------------------------------------------
IncomingGift.OnClientEvent:Connect(function(transactionId, sender, toolName)
	if currentTransactionId then return end -- Already reviewing one
	if closeThread then task.cancel(closeThread) closeThread = nil end

	currentTransactionId = transactionId
	isProcessing = false

	local displayName = toolName:gsub(" Tool", ""):gsub(" Item", "")
	local tier = "Common"
	if CarStats.Cars[displayName] then
		tier = CarStats.Cars[displayName].Rarity
	end
	local tierHex = getRarityColorHex(tier)

	senderLbl.Text = string.format("<font color='#55ff7f'>Received Gift from</font> <font color='#ff0000'>@%s</font>", sanitize(sender.Name))
	whatIsSentLbl.Text = string.format("Sent a <font color='#%s'>[%s]</font> %s", tierHex, tier, displayName)
	avatarImg.Image = "rbxthumb://type=AvatarHeadShot&id=" .. sender.UserId .. "&w=150&h=150"

	statusLbl.Text = "Time remaining: 30s..."
	statusLbl.TextColor3 = Color3.fromRGB(150, 150, 150)

	if acceptConn then acceptConn:Disconnect() end
	if declineConn then declineConn:Disconnect() end

	acceptConn = acceptBtn.MouseButton1Click:Connect(function()
		if isProcessing or not currentTransactionId then return end
		isProcessing = true
		playSfx(SFX.Click, 0.5)
		statusLbl.Text = "Accepting transaction..."
		statusLbl.TextColor3 = Color3.fromRGB(255, 255, 100)
		ResolveGift:FireServer(currentTransactionId, true)
	end)

	declineConn = declineBtn.MouseButton1Click:Connect(function()
		if isProcessing or not currentTransactionId then return end
		isProcessing = true
		playSfx(SFX.Click, 0.5)
		statusLbl.Text = "Declining transaction..."
		statusLbl.TextColor3 = Color3.fromRGB(255, 85, 85)
		ResolveGift:FireServer(currentTransactionId, false)
	end)

	-- Enable and pop in
	screenGui.Enabled = true
	mainFrame.Visible = true

	playSfx(SFX.Incoming, 0.6)
end)

-- ----------------------------------------------------------------------------
-- 🧾 RESULT NOTIFICATION
-- ----------------------------------------------------------------------------
GiftResult.OnClientEvent:Connect(function(success, message, toolId, isSender, otherPlayerName, otherPlayerId)
	if isSender and success and toolId and otherPlayerName then
		local displayName = toolId:gsub(" Tool", ""):gsub(" Item", "")
		local tier = "Common"
		if CarStats.Cars[displayName] then tier = CarStats.Cars[displayName].Rarity end
		showSenderNotification(tier, getRarityColorHex(tier), displayName, otherPlayerName)
	end

	if screenGui and screenGui.Enabled and (not isSender) then
		statusLbl.Text = message
		if success then
			statusLbl.TextColor3 = Color3.fromRGB(85, 255, 127) -- Green
			playSfx(SFX.Success, 0.6)
		else
			statusLbl.TextColor3 = Color3.fromRGB(255, 85, 85) -- Red
			playSfx(SFX.Error, 0.6)
		end
		closeMenu(2.5) -- Close after 2.5 seconds
	end
end)
