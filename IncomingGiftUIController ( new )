-- Purpose: Handles receiving car gifts (Receiver UI) and status updates for the Sender using a Studio-designed label.
-- Runs on: Client
-- Location: StarterPlayerScripts
-- Dependencies: Players, ReplicatedStorage, TweenService, Debris
-- Networking: Listens to 'IncomingGift' & 'GiftResult'. Fires 'ResolveGift'.
-- Security: Sanitizes player names for RichText. Enforces UI visibility state via state-guards.
-- Performance: Utilizes task.cancel on notification threads to prevent flickering and memory leaks.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
local PlayerGui = player:WaitForChild("PlayerGui")

-- 📡 REMOTES & MODULES
local CarStats = require(ReplicatedStorage:WaitForChild("CarStats"))
local Remotes = ReplicatedStorage:WaitForChild("GiftRemotes")
local IncomingGift = Remotes:WaitForChild("IncomingGift")
local ResolveGift = Remotes:WaitForChild("ResolveGift")
local GiftResult = Remotes:WaitForChild("GiftResult")

-- ⚙️ CONFIG & UI REFERENCES
local UI_NAME = "IncomingGiftUI"
local NOTIF_GUI_NAME = "Notifications"
local SENDER_LABEL_NAME = "SentToWho"

local COLOR_USER = "#00FFFF"    -- Bright Cyan for @Usernames
local COLOR_TEXT = "#FFFFFF"    -- White for standard text
local COLOR_SUCCESS = "#55FF7F" -- Green for Accepted
local COLOR_FAIL = "#FF5555"    -- Red for Declined/Error

local HOVER_TWEEN = TweenInfo.new(0.2)
local NORMAL_COLOR = Color3.fromRGB(255, 255, 255)
local DIM_COLOR = Color3.fromRGB(200, 200, 200)

local SFX = {
	Incoming = "rbxassetid://6895079853",
	Click = "rbxassetid://4210586953",
	Success = "rbxassetid://2619623062",
	Error = "rbxassetid://1526487928"
}

-- 👁️ GUI INITIALIZATION
local screenGui = PlayerGui:WaitForChild(UI_NAME, 10)
local mainFrame = screenGui:WaitForChild("MainFrame")
local statusLbl = mainFrame:WaitForChild("StatusLabel")
local acceptBtn = mainFrame:WaitForChild("Buttons"):WaitForChild("AcceptButton")
local declineBtn = mainFrame:WaitForChild("Buttons"):WaitForChild("DeclineButton")

-- Studio Reference for Sender Notifications
local notificationsGui = PlayerGui:WaitForChild(NOTIF_GUI_NAME, 10)
local sentToWhoLbl = notificationsGui:WaitForChild(SENDER_LABEL_NAME, 5)

if sentToWhoLbl then
	sentToWhoLbl.RichText = true
	sentToWhoLbl.Visible = false
end

-- 🛡️ HELPER FUNCTIONS
local function sanitize(str) return str:gsub("<", "&lt;"):gsub(">", "&gt;") end

local function playSfx(soundId, volume)
	local s = Instance.new("Sound")
	s.SoundId = soundId
	s.Volume = volume or 0.5
	s.Parent = PlayerGui
	s:Play()
	Debris:AddItem(s, 3)
end

local function getRarityColorHex(rarity)
	local map = {Common="b4b4b4", Uncommon="32dc32", Rare="3296ff", Epic="b432ff", Legendary="ffb432", Mythic="ff2828"}
	return map[rarity] or "ffffff"
end

-- 💾 STATE
local currentTransactionId = nil
local isProcessing = false
local closeThread = nil
local countdownThread = nil
local senderNotifThread = nil

-- 🟢 NOTIFICATION HANDLER (For Sender)
local function showSenderStatus(richMessage)
	if not sentToWhoLbl then return end

	sentToWhoLbl.Text = richMessage
	sentToWhoLbl.Visible = true

	if senderNotifThread then task.cancel(senderNotifThread) end
	senderNotifThread = task.delay(4, function()
		sentToWhoLbl.Visible = false
		senderNotifThread = nil
	end)
end

local function closeReceiverMenu(delayTime)
	if closeThread then task.cancel(closeThread) closeThread = nil end
	if countdownThread then task.cancel(countdownThread) countdownThread = nil end

	closeThread = task.delay(delayTime or 0, function()
		screenGui.Enabled = false
		currentTransactionId = nil
		isProcessing = false
	end)
end

-- 🟢 INCOMING GIFT (For Receiver)
IncomingGift.OnClientEvent:Connect(function(transactionId, sender, toolName)
	if currentTransactionId then return end
	if closeThread then task.cancel(closeThread) end

	currentTransactionId = transactionId
	isProcessing = false

	local displayName = toolName:gsub(" Tool", ""):gsub(" Item", "")
	local tier = CarStats.Cars[displayName] and CarStats.Cars[displayName].Rarity or "Common"
	local tierHex = getRarityColorHex(tier)

	mainFrame:WaitForChild("SenderLabel").Text = string.format("<font color='#55ff7f'>Received Gift from</font> <font color='%s'>@%s</font>", COLOR_USER, sanitize(sender.Name))
	mainFrame:WaitForChild("WhatIsSent").Text = string.format("Sent a <font color='#%s'>[%s]</font> %s", tierHex, tier, displayName)
	mainFrame:WaitForChild("Avatar").Image = "rbxthumb://type=AvatarHeadShot&id=" .. sender.UserId .. "&w=150&h=150"

	local timeLeft = 30
	statusLbl.TextColor3 = Color3.fromRGB(150, 150, 150)
	countdownThread = task.spawn(function()
		while timeLeft > 0 and not isProcessing do
			statusLbl.Text = string.format("Time remaining: %ds...", timeLeft)
			task.wait(1)
			timeLeft -= 1
		end
	end)

	screenGui.Enabled = true
	mainFrame.Visible = true
	playSfx(SFX.Incoming, 0.6)
end)

-- 🏁 RESOLUTION (Resolve Logic for Receiver Buttons)
local function handleResolution(isAccepted)
	if isProcessing or not currentTransactionId then return end
	isProcessing = true
	playSfx(SFX.Click, 0.5)

	statusLbl.Text = isAccepted and "Accepting..." or "Declining..."
	statusLbl.TextColor3 = isAccepted and Color3.fromRGB(255, 255, 100) or Color3.fromRGB(255, 85, 85)

	ResolveGift:FireServer(currentTransactionId, isAccepted)
end

acceptBtn.MouseButton1Click:Connect(function() handleResolution(true) end)
declineBtn.MouseButton1Click:Connect(function() handleResolution(false) end)

-- 🧾 RESULT NOTIFICATION (Handles both Sender & Receiver feedback)
GiftResult.OnClientEvent:Connect(function(success, message, toolId, isSender, otherPlayerName, otherPlayerId)
	if isSender and otherPlayerName then
		local cleanName = sanitize(otherPlayerName)
		local richMsg = ""

		if success then
			if message == "SENT_PENDING" then
				-- Initial request sent
				richMsg = string.format("<font color='%s'>Sent gift to: </font><font color='%s'>@%s</font>", COLOR_TEXT, COLOR_USER, cleanName)
			else
				-- Acceptance confirmed
				richMsg = string.format("<font color='%s'>Gift </font><font color='%s'>accepted</font><font color='%s'> by </font><font color='%s'>@%s</font>", COLOR_TEXT, COLOR_SUCCESS, COLOR_TEXT, COLOR_USER, cleanName)
			end
		else
			if message:find("declined") then
				-- Explicitly declined
				richMsg = string.format("<font color='%s'>Gift </font><font color='%s'>declined</font><font color='%s'> by </font><font color='%s'>@%s</font>", COLOR_TEXT, COLOR_FAIL, COLOR_TEXT, COLOR_USER, cleanName)
			else
				-- System error (Too far, busy, etc.)
				richMsg = string.format("<font color='%s'>%s</font>", COLOR_FAIL, sanitize(message))
			end
		end
		showSenderStatus(richMsg)
	end

	-- Logic for Receiver UI feedback
	if screenGui.Enabled and (not isSender) then
		if countdownThread then task.cancel(countdownThread) end
		isProcessing = true
		statusLbl.Text = message
		statusLbl.TextColor3 = success and Color3.fromRGB(85, 255, 127) or Color3.fromRGB(255, 85, 85)
		playSfx(success and SFX.Success or SFX.Error, 0.6)
		closeReceiverMenu(2.5)
	end
end)
