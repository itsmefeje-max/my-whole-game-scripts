local function getRarityColorHex(rarity)
	local map = {
		Common = "b4b4b4",
		Uncommon = "32dc32",
		Rare = "3296ff",
		Epic = "b432ff",
		Legendary = "ffb432",
		Mythic = "ff2828"
	}
	return map[rarity] or "ffffff"
end

local function sanitize(str)
	return str:gsub("<", "&lt;"):gsub(">", "&gt;")
end
if not Remotes then
	warn("⚠️ IncomingGiftUI: 'GiftRemotes' missing in ReplicatedStorage!")
