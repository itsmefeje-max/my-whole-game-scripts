-- Purpose: Centralizes MarketplaceService.ProcessReceipt with IDEMPOTENCY, GIFTING, and VFX.
-- Runs on: Server
-- Location: ServerScriptService
-- Dependencies: MarketplaceService, DataStoreService, ServerStorage, ReplicatedStorage, GiftIntentHandler
-- Public API: MarketplaceService.ProcessReceipt (Callback)
-- Networking: Server -> Client via PadUnlockEvent
-- Security: Strict datastore error handling prevents duplicate rewards; safe container checks prevent infinite yields.
-- Performance: Pre-evaluates conditions to ensure clean O(1) or safe O(N) control flow routing.
-- Notes: Assumes GiftIntentHandler (_G.GetGiftReceiver) handles invalid/offline user IDs gracefully.
-- Notes: Assumes GiftIntentHandler (GiftIntentHandler.GetGiftReceiver) handles invalid/offline user IDs gracefully.

local MarketplaceService = game:GetService("MarketplaceService")
local DataStoreService = game:GetService("DataStoreService")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ServerStorage = game:GetService("ServerStorage")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local GiftIntentHandler = require(game:GetService("ServerScriptService"):WaitForChild("GiftIntentHandler"))

-- 💾 DATASTORE FOR RECEIPT HISTORY
local PurchaseHistory = DataStoreService:GetDataStore("PurchaseHistory")

-- ⚙️ EXISTING PRODUCT IDs
local TABLET_2X_ID = 3509697462 -- Tablet ID
local SHOP_REROLL_ID = 3520990584 -- Reroll ID

-- 🚗 CAR PRODUCT IDs
local CAR_PRODUCT_IDS = {
	[3524326648] = "Delta",
	[3524327150] = "Iva",
	[3524327478] = "Atom",
	[3524327780] = "Windsor",
	[3524328208] = "Senator",
	[3524328713] = "Riva"
}

-- 🔗 REFERENCES
local TycoonFolder = Workspace:WaitForChild("Tycoons")
local ShopRerollFunc = ServerStorage:WaitForChild("ShopRerollFunction")

-- 📡 NEW: VFX Event Connection
local PadUnlockEvent = ReplicatedStorage:FindFirstChild("PadUnlockEvent")
if not PadUnlockEvent then
	PadUnlockEvent = Instance.new("RemoteEvent")
	PadUnlockEvent.Name = "PadUnlockEvent"
	PadUnlockEvent.Parent = ReplicatedStorage
end

-- ✅ Base Skin Module Reference
local BaseSkinStats
pcall(function()
	BaseSkinStats = require(ReplicatedStorage:WaitForChild("BaseSkinStats"))
end)

-- ============================================================================
-- 🧾 MAIN RECEIPT PROCESSOR
-- ============================================================================
MarketplaceService.ProcessReceipt = function(receiptInfo)
	local buyerId = receiptInfo.PlayerId
	local buyerPlayer = Players:GetPlayerByUserId(buyerId)

	-- 1. Handle Buyer Leaving/Crashing
	if not buyerPlayer then return Enum.ProductPurchaseDecision.NotProcessedYet end

	-- 🎁 GIFTING LOGIC: Determine the Recipient
	local targetPlayer = buyerPlayer -- Default to buyer
	local isGift = false

	if GiftIntentHandler and GiftIntentHandler.GetGiftReceiver then
		local receiverId = GiftIntentHandler.GetGiftReceiver(buyerId)
		if receiverId then
			local receiver = Players:GetPlayerByUserId(receiverId)
			if receiver then
				targetPlayer = receiver
				isGift = true
				print("🎁 GIFT DETECTED! From " .. buyerPlayer.Name .. " to " .. targetPlayer.Name)
			else
				warn("⚠️ Gift Receiver (ID: " .. tostring(receiverId) .. ") is offline. Defaulting item to Buyer.")
			end
		end
	end

	-- 🛡️ SECURITY: IDEMPOTENCY CHECK
	local purchaseKey = buyerId .. "_" .. receiptInfo.PurchaseId
	local success, alreadyProcessed = pcall(function()
		return PurchaseHistory:GetAsync(purchaseKey)
	end)

	if not success then 
		warn("⚠️ DataStore Error during receipt check. Retrying...")
		return Enum.ProductPurchaseDecision.NotProcessedYet 
	end

	if alreadyProcessed then
		print("♻️ Duplicate Purchase ID detected. Skipping reward.")
		return Enum.ProductPurchaseDecision.PurchaseGranted
	end

	-- Proceed with Purchase Logic
	local pid = receiptInfo.ProductId
	local purchaseSuccess = false 

	print("🛒 Processing Purchase for ProductID: " .. pid .. " | Receiver: " .. targetPlayer.Name)

	-- 🛑 FIX: Pre-evaluate Skin Match to avoid control flow hijacking
	local skinFound = nil
	if BaseSkinStats then
		for name, data in pairs(BaseSkinStats) do
			if data.ProductId == pid then
				skinFound = name
				break
			end
		end
	end

	-- ====================================================
	-- 1️⃣ PRODUCT: TABLET 2X EARNINGS
	-- ====================================================
	if pid == TABLET_2X_ID then
		local myPlotName = targetPlayer:GetAttribute("OccupiedPlot")
		local plot = myPlotName and TycoonFolder:FindFirstChild(myPlotName)

		if plot and plot:FindFirstChild("PendingEarnings") then 
			local pendingVal = plot.PendingEarnings
			local amount = pendingVal.Value

			if amount > 0 then
				pendingVal.Value = 0
				local ls = targetPlayer:FindFirstChild("leaderstats")
				if ls and ls:FindFirstChild("Cash") then
					ls.Cash.Value += (amount * 2)
				end
			end
			purchaseSuccess = true
		end

		-- ====================================================
		-- 2️⃣ PRODUCT: SHOP REROLL (Restock)
		-- ====================================================
	elseif pid == SHOP_REROLL_ID then
		if ShopRerollFunc then
			ShopRerollFunc:Invoke(targetPlayer) 
			purchaseSuccess = true
		else
			warn("⚠️ Critical: ShopRerollFunction missing!")
		end

		-- ====================================================
		-- 3️⃣ PRODUCT: BUY CAR WITH ROBUX
		-- ====================================================
	elseif CAR_PRODUCT_IDS[pid] then
		local carName = CAR_PRODUCT_IDS[pid]
		local CarTools = ServerStorage:FindFirstChild("CarTools")
		local tool = CarTools and (CarTools:FindFirstChild(carName) or CarTools:FindFirstChild(carName.." Item"))

		if tool then
			-- 🛑 SECURE DATASORE WRITE: Lock the purchase ID before granting
			local dataSuccess, err = pcall(function()
				PurchaseHistory:SetAsync(purchaseKey, true)
			end)

			if not dataSuccess then
				warn("⚠️ Datastore down. Halting grant to prevent dupe. " .. tostring(err))
				return Enum.ProductPurchaseDecision.NotProcessedYet
			end

			local AdminAPI = game:GetService("ServerStorage"):FindFirstChild("TycoonAdminAPI")
			if AdminAPI then
				AdminAPI:Invoke("GiveTool", targetPlayer, tool.Name)
			else
				warn("⚠️ AdminAPI missing in ReceiptRouter")
			end

			if isGift then
				print("✅ Gift successfully delivered to " .. targetPlayer.Name)
			end
			return Enum.ProductPurchaseDecision.PurchaseGranted
		else
			warn("❌ Critical: Tool missing for Robux Car: " .. carName)
		end

		-- ====================================================
		-- 4️⃣ PRODUCT: BASE SKINS (Silver/Gold/Diamond/Rainbow)
		-- ====================================================
	elseif skinFound then
		local ownedRaw = targetPlayer:GetAttribute("OwnedBaseSkins") or "[]"
		local ownedTable = {}
		local decodeSuccess, _ = pcall(function() ownedTable = HttpService:JSONDecode(ownedRaw) end)
		if not decodeSuccess then ownedTable = {} end

		if not table.find(ownedTable, skinFound) then
			table.insert(ownedTable, skinFound)
			targetPlayer:SetAttribute("OwnedBaseSkins", HttpService:JSONEncode(ownedTable))
		end

		targetPlayer:SetAttribute("EquippedSkin", skinFound)
		purchaseSuccess = true

		-- ✨ NEW: TRIGGER CLIENT SUCCESS FOR ROBUX PURCHASES
		if PadUnlockEvent then
			PadUnlockEvent:FireClient(targetPlayer, true, skinFound .. " Base")
		end

	else
		warn("⚠️ Unknown ProductID Purchased: " .. pid)
	end

	-- ====================================================
	-- 🏁 FINALIZE PURCHASE (For non-car items)
	-- ====================================================
	if purchaseSuccess then
		local dataSuccess, dataErr = pcall(function()
			PurchaseHistory:SetAsync(purchaseKey, true)
		end)

		if not dataSuccess then
			warn("⚠️ Critical Datastore Error saving receipt: " .. tostring(dataErr))
			return Enum.ProductPurchaseDecision.NotProcessedYet
		end

		if isGift then
			print("✅ Gift successfully delivered to " .. targetPlayer.Name)
		end

		return Enum.ProductPurchaseDecision.PurchaseGranted
	else
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end
end
