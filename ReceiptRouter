-- ============================================================================
-- ⏱️ TIMEOUT UTILITY
-- ============================================================================
local function safeInvoke(bindable, timeout, ...)
	local args = table.pack(...)
	local result = nil
	local finished = false

	task.spawn(function()
		result = table.pack(pcall(function()
			return bindable:Invoke(table.unpack(args, 1, args.n))
		end))
		finished = true
	end)

	local start = os.clock()
	while not finished and (os.clock() - start) < timeout do
		task.wait()
	end

	if not finished then return false, "Timeout" end
	if not result[1] then return false, result[2] end

	return true, table.unpack(result, 2, result.n)
end

local function getPurchaseHistoryStore()
	if ActivePurchaseHistory then return ActivePurchaseHistory end

	for _, name in ipairs(PURCHASE_HISTORY_NAMES) do
		local ok, store = pcall(function() return DataStoreService:GetDataStore(name) end)
		if ok and store then
			ActivePurchaseHistory = store
			return ActivePurchaseHistory
		end
	end
	return nil
end

local function isDeletedStoreError(err)
	err = string.lower(tostring(err or ""))
	return string.find(err, "data store is deleted", 1, true) ~= nil
end

local function wasPurchaseProcessed(purchaseKey)
	local store = getPurchaseHistoryStore()
	if not store then return nil end

	for attempt = 1, 3 do
		local success, result = pcall(function() return store:GetAsync(purchaseKey) end)
		if success then return result == true end

		if isDeletedStoreError(result) then
			local fallbackOk, fallbackStore = pcall(function() return DataStoreService:GetDataStore("PurchaseHistory_V2") end)
			if fallbackOk and fallbackStore then
				ActivePurchaseHistory = fallbackStore
				store = ActivePurchaseHistory
			else
				return nil
			end
		else
			task.wait(0.25 * attempt)
		end
	end
	return nil
end

local function markPurchaseProcessed(purchaseKey)
	local store = getPurchaseHistoryStore()
	if not store then return false end

	local success, err = pcall(function()
		store:UpdateAsync(purchaseKey, function(current) return true end)
	end)

	if not success then return false end
	return true
end

-- ============================================================================
-- 🧾 MAIN RECEIPT PROCESSOR
-- ============================================================================
MarketplaceService.ProcessReceipt = function(receiptInfo)
	local buyerId = receiptInfo.PlayerId
	local buyerPlayer = Players:GetPlayerByUserId(buyerId)

	if not buyerPlayer then return Enum.ProductPurchaseDecision.NotProcessedYet end

	local targetPlayer = buyerPlayer
	local isGift = false

	if _G.GetGiftReceiver then
		local receiverId = _G.GetGiftReceiver(buyerId)
		if receiverId then
			local receiver = Players:GetPlayerByUserId(receiverId)
			if receiver then
				targetPlayer = receiver
				isGift = true
			end
		end
	end

	local purchaseKey = buyerId .. "_" .. receiptInfo.PurchaseId
	local alreadyProcessed = wasPurchaseProcessed(purchaseKey)
	if alreadyProcessed == nil then
		return Enum.ProductPurchaseDecision.NotProcessedYet 
	end

	if alreadyProcessed then
		return Enum.ProductPurchaseDecision.PurchaseGranted
	end

	local pid = receiptInfo.ProductId
	local purchaseSuccess = false 

	local skinFound = nil
	if BaseSkinStats then
		for name, data in pairs(BaseSkinStats) do
			if data.ProductId == pid then
				skinFound = name
				break
			end
		end
	end

	if pid == TABLET_2X_ID then
		local myPlotName = targetPlayer:GetAttribute("OccupiedPlot")
		local plot = myPlotName and TycoonFolder:FindFirstChild(myPlotName)

		if plot and plot:FindFirstChild("PendingEarnings") then 
			local pendingVal = plot.PendingEarnings
			local amount = pendingVal.Value

			if amount > 0 then
				pendingVal.Value = 0
				local ls = targetPlayer:FindFirstChild("leaderstats")
				if ls and ls:FindFirstChild("Cash") then
					ls.Cash.Value += (amount * 2)
				end
			end
			purchaseSuccess = true
		end

	elseif pid == SHOP_REROLL_ID then
		if ShopRerollFunc then
			ShopRerollFunc:Invoke(targetPlayer) 
			purchaseSuccess = true
		end

		-- ✅ NEW: UNCOMMON REROLL LOGIC
	elseif pid == UNCOMMON_SHOP_REROLL_ID then
		if UncommonShopRerollFunc then
			UncommonShopRerollFunc:Invoke(targetPlayer)
			purchaseSuccess = true
		else
			warn("⚠️ UncommonShopRerollFunction missing!")
		end

		-- 🚗 COMMON CAR PURCHASE LOGIC
	elseif CAR_PRODUCT_IDS[pid] then
		local carName = CAR_PRODUCT_IDS[pid]
		local CarTools = ServerStorage:FindFirstChild("CarTools")
		local tool = CarTools and (CarTools:FindFirstChild(carName) or CarTools:FindFirstChild(carName.." Item"))

		if tool then
			local TycoonAdminAPI = ServerStorage:FindFirstChild("TycoonAdminAPI")
			if TycoonAdminAPI then
				local invokeOk, giveResult = safeInvoke(TycoonAdminAPI, 3, "GiveTool", targetPlayer, tool.Name, {
					IssuedByServer = true,
					IssuedAt = os.time(),
					ToolId = tool.Name
				})

				if invokeOk and giveResult == true then
					purchaseSuccess = true
				end
			end
		end

		-- 🏎️ NEW: UNCOMMON CAR PURCHASE LOGIC
	elseif UNCOMMON_CAR_PRODUCT_IDS[pid] then
		local carName = UNCOMMON_CAR_PRODUCT_IDS[pid]
		local CarTools = ServerStorage:FindFirstChild("CarTools")
		local tool = CarTools and (CarTools:FindFirstChild(carName) or CarTools:FindFirstChild(carName.." Item"))

		if tool then
			local TycoonAdminAPI = ServerStorage:FindFirstChild("TycoonAdminAPI")
			if TycoonAdminAPI then
				-- Grant the tool exactly like the Common shop does
				local invokeOk, giveResult = safeInvoke(TycoonAdminAPI, 3, "GiveTool", targetPlayer, tool.Name, {
					IssuedByServer = true,
					IssuedAt = os.time(),
					ToolId = tool.Name
				})

				if invokeOk and giveResult == true then
					purchaseSuccess = true
				end
			end
		else
			warn("⚠️ Uncommon Car Tool missing from ServerStorage: " .. carName)
		end

	elseif skinFound then
		local ownedRaw = targetPlayer:GetAttribute("OwnedBaseSkins") or "[]"
		local ownedTable = {}
		local decodeSuccess, _ = pcall(function() ownedTable = HttpService:JSONDecode(ownedRaw) end)
		if not decodeSuccess then ownedTable = {} end

		if table.find(ownedTable, skinFound) then
			warn("🛡️ Security: Blocked purchase! " .. targetPlayer.Name .. " already owns the " .. skinFound .. " pad.")
			return Enum.ProductPurchaseDecision.NotProcessedYet 
		else
			table.insert(ownedTable, skinFound)
			targetPlayer:SetAttribute("OwnedBaseSkins", HttpService:JSONEncode(ownedTable))
			targetPlayer:SetAttribute("EquippedSkin", skinFound)
			purchaseSuccess = true

			if PadUnlockEvent and not isGift then
				PadUnlockEvent:FireClient(targetPlayer, true, skinFound .. " Base")
			end

			if isGift then
				NotifyGiftReceived:FireClient(targetPlayer, buyerPlayer.Name, skinFound)
			end
		end
	end

	if purchaseSuccess then
		if not markPurchaseProcessed(purchaseKey) then
			return Enum.ProductPurchaseDecision.NotProcessedYet
		end

		local TycoonAdminAPI = ServerStorage:FindFirstChild("TycoonAdminAPI")
		if TycoonAdminAPI then
			task.spawn(function()
				safeInvoke(TycoonAdminAPI, 2, "MarkDirty", targetPlayer)
			end)
		end

		return Enum.ProductPurchaseDecision.PurchaseGranted
	else
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end
end
