-- Purpose: Centralizes MarketplaceService.ProcessReceipt with IDEMPOTENCY, GIFTING, and VFX.
-- Runs on: Server
-- Location: ServerScriptService
-- Dependencies: MarketplaceService, DataStoreService, ServerStorage, ReplicatedStorage, GiftIntentHandler
-- Public API: MarketplaceService.ProcessReceipt (Callback)
-- Networking: Server -> Client via PadUnlockEvent
-- Security: Strict datastore error handling prevents duplicate rewards; safe container checks prevent infinite yields.
-- Performance: Pre-evaluates conditions to ensure clean O(1) or safe O(N) control flow routing.
-- Notes: Assumes GiftIntentHandler (_G.GetGiftReceiver) handles invalid/offline user IDs gracefully.

local MarketplaceService = game:GetService("MarketplaceService")
local DataStoreService = game:GetService("DataStoreService")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ServerStorage = game:GetService("ServerStorage")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

-- 💾 DATASTORE FOR RECEIPT HISTORY
-- NOTE: "PurchaseHistory" was previously deleted in production.
-- Keep a fallback name so receipt processing can recover safely.
local PURCHASE_HISTORY_NAMES = {"PurchaseHistory", "PurchaseHistory_V2"}
local ActivePurchaseHistory = nil

-- ⚙️ EXISTING PRODUCT IDs
local TABLET_2X_ID = 3509697462 -- Tablet ID
local SHOP_REROLL_ID = 3520990584 -- Reroll ID

-- 🚗 CAR PRODUCT IDs
local CAR_PRODUCT_IDS = {
	[3524326648] = "Delta",
	[3524327150] = "Iva",
	[3524327478] = "Atom",
	[3524327780] = "Windsor",
	[3524328208] = "Senator",
	[3524328713] = "Riva"
}

-- 🔗 REFERENCES
local TycoonFolder = Workspace:WaitForChild("Tycoons")
local ShopRerollFunc = ServerStorage:WaitForChild("ShopRerollFunction")

-- 📡 NEW: VFX Event Connection
local PadUnlockEvent = ReplicatedStorage:FindFirstChild("PadUnlockEvent")
if not PadUnlockEvent then
	PadUnlockEvent = Instance.new("RemoteEvent")
	PadUnlockEvent.Name = "PadUnlockEvent"
	PadUnlockEvent.Parent = ReplicatedStorage
end

-- ✅ Base Skin Module Reference
local BaseSkinStats
pcall(function()
	BaseSkinStats = require(ReplicatedStorage:WaitForChild("BaseSkinStats"))
end)

local function getPurchaseHistoryStore()
	if ActivePurchaseHistory then
		return ActivePurchaseHistory
	end

	for _, name in ipairs(PURCHASE_HISTORY_NAMES) do
		local ok, store = pcall(function()
			return DataStoreService:GetDataStore(name)
		end)
		if ok and store then
			ActivePurchaseHistory = store
			return ActivePurchaseHistory
		end
	end

	return nil
end

local function isDeletedStoreError(err)
	err = string.lower(tostring(err or ""))
	return string.find(err, "data store is deleted", 1, true) ~= nil
end

local function playerHasTool(player, toolName)
	if not player or not toolName then return false end

	local function hasToolIn(container)
		if not container then return false end
		for _, item in ipairs(container:GetChildren()) do
			if item:IsA("Tool") then
				local toolId = item:GetAttribute("ToolId")
				if item.Name == toolName or toolId == toolName then
					return true
				end
			end
		end
		return false
	end

	return hasToolIn(player:FindFirstChild("Backpack"))
		or hasToolIn(player:FindFirstChild("StarterGear"))
		or hasToolIn(player.Character)
end

local function grantToolDirectly(player, sourceTool)
	if not player or not sourceTool then return false end

	local backpack = player:FindFirstChild("Backpack")
	local starterGear = player:FindFirstChild("StarterGear")

	if not backpack and not starterGear then
		warn("⚠️ Cannot grant tool: Backpack and StarterGear are missing for " .. player.Name)
		return false
	end

	local function tag(tool)
		tool:SetAttribute("IssuedByServer", true)
		tool:SetAttribute("IssuedAt", os.time())
		tool:SetAttribute("IssuedId", HttpService:GenerateGUID(false))
		tool:SetAttribute("ToolId", sourceTool.Name)
		return tool
	end

	if backpack then
		tag(sourceTool:Clone()).Parent = backpack
	end

	if starterGear then
		local alreadyInStarterGear = false
		for _, child in ipairs(starterGear:GetChildren()) do
			if child:IsA("Tool") and child:GetAttribute("ToolId") == sourceTool.Name then
				alreadyInStarterGear = true
				break
			end
		end

		if not alreadyInStarterGear then
			tag(sourceTool:Clone()).Parent = starterGear
		end
	end

	return playerHasTool(player, sourceTool.Name)
end

local function wasPurchaseProcessed(purchaseKey)
	local store = getPurchaseHistoryStore()
	if not store then
		warn("⚠️ PurchaseHistory DataStore unavailable.")
		return nil
	end

	for attempt = 1, 3 do
		local success, result = pcall(function()
			return store:GetAsync(purchaseKey)
		end)

		if success then
			return result == true
		end

		if isDeletedStoreError(result) then
			warn("⚠️ Receipt DataStore was deleted. Switching to fallback store.")
			local fallbackOk, fallbackStore = pcall(function()
				return DataStoreService:GetDataStore("PurchaseHistory_V2")
			end)
			if fallbackOk and fallbackStore then
				ActivePurchaseHistory = fallbackStore
				store = ActivePurchaseHistory
			else
				return nil
			end
		else
			warn("⚠️ DataStore Error during receipt check. Retrying... Attempt " .. attempt)
			task.wait(0.25 * attempt)
		end
	end

	return nil
end

local function markPurchaseProcessed(purchaseKey)
	local store = getPurchaseHistoryStore()
	if not store then
		warn("⚠️ PurchaseHistory DataStore unavailable during save.")
		return false
	end

	local success, err = pcall(function()
		store:UpdateAsync(purchaseKey, function(current)
			if current == true then
				return true
			end
			return true
		end)
	end)

	if not success then
		warn("⚠️ Critical Datastore Error saving receipt: " .. tostring(err))
		return false
	end

	return true
end

-- ============================================================================
-- 🧾 MAIN RECEIPT PROCESSOR
-- ============================================================================
MarketplaceService.ProcessReceipt = function(receiptInfo)
	local buyerId = receiptInfo.PlayerId
	local buyerPlayer = Players:GetPlayerByUserId(buyerId)

	-- 1. Handle Buyer Leaving/Crashing
	if not buyerPlayer then return Enum.ProductPurchaseDecision.NotProcessedYet end

	-- 🎁 GIFTING LOGIC: Determine the Recipient
	local targetPlayer = buyerPlayer -- Default to buyer
	local isGift = false

	if _G.GetGiftReceiver then
		local receiverId = _G.GetGiftReceiver(buyerId)
		if receiverId then
			local receiver = Players:GetPlayerByUserId(receiverId)
			if receiver then
				targetPlayer = receiver
				isGift = true
				print("🎁 GIFT DETECTED! From " .. buyerPlayer.Name .. " to " .. targetPlayer.Name)
			else
				warn("⚠️ Gift Receiver (ID: " .. tostring(receiverId) .. ") is offline. Defaulting item to Buyer.")
			end
		end
	end

	-- 🛡️ SECURITY: IDEMPOTENCY CHECK
	local purchaseKey = buyerId .. "_" .. receiptInfo.PurchaseId
	local alreadyProcessed = wasPurchaseProcessed(purchaseKey)
	if alreadyProcessed == nil then
		return Enum.ProductPurchaseDecision.NotProcessedYet 
	end

	if alreadyProcessed then
		print("♻️ Duplicate Purchase ID detected. Skipping reward.")
		return Enum.ProductPurchaseDecision.PurchaseGranted
	end

	-- Proceed with Purchase Logic
	local pid = receiptInfo.ProductId
	local purchaseSuccess = false 

	print("🛒 Processing Purchase for ProductID: " .. pid .. " | Receiver: " .. targetPlayer.Name)

	-- 🛑 FIX: Pre-evaluate Skin Match to avoid control flow hijacking
	local skinFound = nil
	if BaseSkinStats then
		for name, data in pairs(BaseSkinStats) do
			if data.ProductId == pid then
				skinFound = name
				break
			end
		end
	end

	-- ====================================================
	-- 1️⃣ PRODUCT: TABLET 2X EARNINGS
	-- ====================================================
	if pid == TABLET_2X_ID then
		local myPlotName = targetPlayer:GetAttribute("OccupiedPlot")
		local plot = myPlotName and TycoonFolder:FindFirstChild(myPlotName)

		if plot and plot:FindFirstChild("PendingEarnings") then 
			local pendingVal = plot.PendingEarnings
			local amount = pendingVal.Value

			if amount > 0 then
				pendingVal.Value = 0
				local ls = targetPlayer:FindFirstChild("leaderstats")
				if ls and ls:FindFirstChild("Cash") then
					ls.Cash.Value += (amount * 2)
				end
			end
			purchaseSuccess = true
		end

		-- ====================================================
		-- 2️⃣ PRODUCT: SHOP REROLL (Restock)
		-- ====================================================
	elseif pid == SHOP_REROLL_ID then
		if ShopRerollFunc then
			ShopRerollFunc:Invoke(targetPlayer) 
			purchaseSuccess = true
		else
			warn("⚠️ Critical: ShopRerollFunction missing!")
		end

		-- ====================================================
		-- 3️⃣ PRODUCT: BUY CAR WITH ROBUX
		-- ====================================================
	elseif CAR_PRODUCT_IDS[pid] then
		local carName = CAR_PRODUCT_IDS[pid]
		local CarTools = ServerStorage:FindFirstChild("CarTools")
		local tool = CarTools and (CarTools:FindFirstChild(carName) or CarTools:FindFirstChild(carName.." Item"))

		if tool then
			if playerHasTool(targetPlayer, tool.Name) then
				purchaseSuccess = true
			else
				local TycoonAdminAPI = ServerStorage:FindFirstChild("TycoonAdminAPI")
				local grantWorked = false

				if TycoonAdminAPI then
					local invokeOk, invokeResult = pcall(function()
						return TycoonAdminAPI:Invoke("GiveTool", targetPlayer, tool.Name, {
							IssuedByServer = true,
							IssuedAt = os.time(),
							ToolId = tool.Name
						})
					end)

					if invokeOk and invokeResult == true and playerHasTool(targetPlayer, tool.Name) then
						grantWorked = true
					end
				end

				if not grantWorked then
					warn("⚠️ TycoonAdminAPI grant failed/unavailable. Using direct fallback grant for " .. targetPlayer.Name)
					grantWorked = grantToolDirectly(targetPlayer, tool)
				end

				if not grantWorked then
					warn("⚠️ Failed to grant Robux car '" .. carName .. "' to " .. targetPlayer.Name)
					return Enum.ProductPurchaseDecision.NotProcessedYet
				end

				purchaseSuccess = true
			end
		else
			warn("❌ Critical: Tool missing for Robux Car: " .. carName)
		end

		-- ====================================================
		-- 4️⃣ PRODUCT: BASE SKINS (Silver/Gold/Diamond/Rainbow)
		-- ====================================================
	elseif skinFound then
		local ownedRaw = targetPlayer:GetAttribute("OwnedBaseSkins") or "[]"
		local ownedTable = {}
		local decodeSuccess, _ = pcall(function() ownedTable = HttpService:JSONDecode(ownedRaw) end)
		if not decodeSuccess then ownedTable = {} end

		if not table.find(ownedTable, skinFound) then
			table.insert(ownedTable, skinFound)
			targetPlayer:SetAttribute("OwnedBaseSkins", HttpService:JSONEncode(ownedTable))
		end

		targetPlayer:SetAttribute("EquippedSkin", skinFound)
		purchaseSuccess = true

		-- ✨ NEW: TRIGGER CLIENT SUCCESS FOR ROBUX PURCHASES
		if PadUnlockEvent then
			PadUnlockEvent:FireClient(targetPlayer, true, skinFound .. " Base")
		end

	else
		warn("⚠️ Unknown ProductID Purchased: " .. pid)
	end

	-- ====================================================
	-- 🏁 FINALIZE PURCHASE (For non-car items)
	-- ====================================================
	if purchaseSuccess then
		if not markPurchaseProcessed(purchaseKey) then
			return Enum.ProductPurchaseDecision.NotProcessedYet
		end

		if isGift then
			print("✅ Gift successfully delivered to " .. targetPlayer.Name)
		end

		return Enum.ProductPurchaseDecision.PurchaseGranted
	else
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end
end
