-- Purpose: Updates the AmountInput with the maximum available balance, or toggles to 0 if already at max.
-- Runs on: Client
-- Location: StarterGui / PlayerGui -> BankGui -> MaxButton
-- Dependencies: Players, SoundService
-- Public API: None
-- Networking: None (UI display only)
-- Security: Completely safe; relies entirely on server validation for actual transfers.
-- Performance: Minimal memory footprint.
-- Notes: Uses stateless toggle logic to prevent desyncs if the user manually types in the box.

print("✅ Max Button Script Loaded (Toggle Edition)")

local Players = game:GetService("Players")
local SoundService = game:GetService("SoundService")

local player = Players.LocalPlayer
local leaderstats = player:WaitForChild("leaderstats", 10)
local button = script.Parent
local mainWindow = button.Parent 

-- 📂 UI REFERENCES
local AmountInput = mainWindow:WaitForChild("AmountInput", 5)

-- 🔊 SOUND CONFIG
local CLICK_SOUND_ID = "rbxassetid://9083627113" 

button.MouseButton1Click:Connect(function()
	print("🖱️ MAX Button Clicked")

	-- 1. Get Current Bank Balance
	local currentBank = 0
	local cashValue = leaderstats and leaderstats:FindFirstChild("Cash")
	if cashValue then
		currentBank = math.floor(cashValue.Value)
	end

	-- 2. Play Click Sound
	local s = Instance.new("Sound")
	s.SoundId = CLICK_SOUND_ID
	s.Volume = 0.5
	s.Parent = SoundService
	s:Play()
	game.Debris:AddItem(s, 2)

	-- 3. Toggle Logic
	if AmountInput then
		local maxBankString = tostring(currentBank)

		-- If the input box already matches the max amount exactly, toggle it to 0
		if AmountInput.Text == maxBankString and currentBank > 0 then
			AmountInput.Text = "0"
			print("🔄 Toggled back to 0")
		else
			-- Otherwise, fill it with the max amount
			if currentBank > 0 then
				AmountInput.Text = maxBankString
				print("✅ Input auto-filled with: " .. AmountInput.Text)
			else
				AmountInput.Text = "0"
			end
		end
	else
		warn("⚠️ AmountInput not found in parent frame! Cannot auto-fill.")
	end
end)
