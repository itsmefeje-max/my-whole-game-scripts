-- Purpose: Handles Uncommon Car Shop logic. Strictly 1 car, 1 stock, every 30 minutes. Includes Pre-Flight Validation.
-- Runs on: Server
-- Location: ServerScriptService > UncommonShopService
-- Dependencies: ReplicatedStorage.CarStats, ServerStorage.TycoonAdminAPI, ServerStorage.CarTools
-- Public API: None (Event/Bindable driven)
-- Networking: OpenUncommonShop, UncommonShopUpdate, GetUncommonShopState, BuyUncommonCar
-- Security: Server authority on cash, strict 1-stock limits, debounce locks, strict NPC proximity checks, and startup validation.
-- Performance: O(1) lookups for shop state. Caches generated seed tables.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

-- =========================
-- UNCOMMON CONFIG (BRUTAL RARITY)
-- =========================
local CAR_WEIGHTS = {Raiju = 50, Ironclad = 28, Vapid = 14, Galadriel = 6, Kingston = 2}
local ALWAYS_STOCK = {} -- DISABLED: Nothing is guaranteed

local RESTOCK_INTERVAL = 1800 -- 30 Minutes (1800 seconds)
local PURCHASE_COOLDOWN = 1.0 -- Cooldown to prevent spam
local MAX_STOCK = 1 -- Only 1 available per restock
local MAX_INTERACTION_DISTANCE = 20 -- Max studs from Darrel to interact/buy

-- =========================
-- 🚨 PRE-FLIGHT HIERARCHY VALIDATION
-- =========================
local function validateDependencies()
	local missing = {}

	if not ReplicatedStorage:FindFirstChild("CarStats") then table.insert(missing, "ReplicatedStorage.CarStats (ModuleScript)") end
	if not ServerStorage:FindFirstChild("TycoonAdminAPI") then table.insert(missing, "ServerStorage.TycoonAdminAPI (BindableFunction)") end
	if not ServerStorage:FindFirstChild("CarTools") then table.insert(missing, "ServerStorage.CarTools (Folder)") end

	local npcs = workspace:FindFirstChild("NPCS")
	if not npcs then 
		table.insert(missing, "workspace.NPCS (Folder)") 
	else
		if not npcs:FindFirstChild("Darrel") then table.insert(missing, "workspace.NPCS.Darrel (Model)") end
	end

	if #missing > 0 then
		warn("⚠️ [UNCOMMON SHOP FATAL ERROR] Missing critical dependencies! The shop will break when players try to buy.")
		for _, err in ipairs(missing) do
			warn("   -> " .. err)
		end
	else
		print("✅ [UncommonShopService] All dependencies found. Service started successfully.")
	end
end

-- Run validation immediately on startup
validateDependencies()

